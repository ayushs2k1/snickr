<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= typeof title !== 'undefined' ? title : 'snickr' %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<header>
  <a class="brand" href="/">snickr</a>
  <nav>
    <% if (me) { %>
      <form action="/search" method="get" class="searchbar">
        <input type="text" name="q" placeholder="Search messages..." value="<%= typeof q !== 'undefined' ? q : '' %>">
        <button>Search</button>
      </form>
      <span class="me">@<%= me.username %></span>
      <form action="/logout" method="post" style="display:inline">
        <button class="link">Log out</button>
      </form>
    <% } else { %>
      <a href="/login">Log in</a> · <a href="/register">Register</a>
    <% } %>
  </nav>
</header>
<% if (flash) { %>
  <div class="flash flash-<%= flash.kind %>"><%= flash.msg %></div>
<% } %>
<main>
