<%- include('_header', { title: 'snickr - home' }) %>
<h1>Hi, <%= me.nickname %>!</h1>

<section>
  <h2>Your workspaces</h2>
  <% if (!workspaces.length) { %><p>You're not in any workspaces yet.</p><% } %>
  <ul class="ws-list">
    <% workspaces.forEach(w => { %>
      <li>
        <a href="/w/<%= w.workspace_id %>"><%= w.name %></a>
        <% if (w.is_admin) { %><span class="badge">admin</span><% } %>
        <% if (w.description) { %><span class="muted"> — <%= w.description %></span><% } %>
      </li>
    <% }); %>
  </ul>

  <details>
    <summary>Create a new workspace</summary>
    <form method="post" action="/workspaces" class="card">
      <label>Name        <input name="name" required></label>
      <label>Description <input name="description"></label>
      <button>Create</button>
    </form>
  </details>
</section>

<section>
  <h2>Pending workspace invitations</h2>
  <% if (!wsInvites.length) { %><p class="muted">None.</p><% } %>
  <ul>
    <% wsInvites.forEach(i => { %>
      <li>
        <strong><%= i.name %></strong> — invited by @<%= i.invited_by %> on <%= i.invited_at.toLocaleString() %>
        <form method="post" action="/invitations/workspace/<%= i.workspace_id %>/accept"  style="display:inline"><button>Accept</button></form>
        <form method="post" action="/invitations/workspace/<%= i.workspace_id %>/decline" style="display:inline"><button class="link">Decline</button></form>
      </li>
    <% }); %>
  </ul>
</section>

<section>
  <h2>Pending channel invitations</h2>
  <% if (!chInvites.length) { %><p class="muted">None.</p><% } %>
  <ul>
    <% chInvites.forEach(i => { %>
      <li>
        <strong>#<%= i.channel_name || '(direct)' %></strong>
        in <a href="/w/<%= i.workspace_id %>"><%= i.workspace_name %></a>
        — by @<%= i.invited_by %> on <%= i.invited_at.toLocaleString() %>
        <form method="post" action="/invitations/channel/<%= i.channel_id %>/accept"  style="display:inline"><button>Accept</button></form>
        <form method="post" action="/invitations/channel/<%= i.channel_id %>/decline" style="display:inline"><button class="link">Decline</button></form>
      </li>
    <% }); %>
  </ul>
</section>

<%- include('_footer') %>
