<%- include('_header', { title: 'Reset Password' }) %>
<h1>Reset Password</h1>

<% if (err) { %><p class="err"><%= err %></p><% } %>
<% if (success) { %>
  <p class="ok"><%= success %></p>
  <p><a href="/login">Go to login</a></p>
<% } else { %>
  <form method="post" action="/reset-password" class="card">
    <label>Username  <input name="username" value="<%= form.username || '' %>" required></label>
    <label>Email     <input name="email" type="email" value="<%= form.email || '' %>" required></label>
    <label>New Password     <input name="password" type="password" required></label>
    <label>Confirm Password <input name="confirm"  type="password" required></label>
    <button>Reset Password</button>
  </form>
  <p><a href="/login">← Back to login</a></p>
<% } %>

<%- include('_footer') %>
